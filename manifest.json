{
	"manifest_version": 3,
	"name": "Kamil",
	"version": "1.0.0",
	"description": "De digitale kameleon die 50-plussers beschermt tegen phishing.",
	"permissions": ["tabs", "storage"],
	"host_permissions": ["http://localhost:5001/*"],
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_popup": "popup/popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	}
}
